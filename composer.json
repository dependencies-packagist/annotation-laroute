{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "annotation/laroute",
    "description": "Auto register routes using PHP attributes for Laravel.",
    "keywords": [
        "laravel",
        "annotation",
        "attributes",
        "route",
        "router",
        "routing"
    ],
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/dependencies-packagist/laroute",
    "authors": [
        {
            "name": "jundayw",
            "email": "jundayw@126.com"
        }
    ],
    "require": {
        "php": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "Annotation\\Routing\\": "src/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.x-dev"
        },
        "laravel": {
            "providers": [
                "Annotation\\Routing\\RoutingServiceProvider"
            ],
            "aliases": {
                "Route": "Annotation\\Routing\\Facades\\Route"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
